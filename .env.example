# =====================================================================
# GarudaChip configuration — copy to ".env" and edit as needed.
#   cp .env.example .env
# =====================================================================

# ---------------------------------------------------------------------
# CHAT MODEL PROVIDER
#   ollama  -> local models served by Ollama (DEFAULT, fully offline)
#   google  -> Google Gemini cloud (needs GOOGLE_API_KEY)
# ---------------------------------------------------------------------
LLM_PROVIDER=ollama

# --- Ollama (local) -------------------------------------------------
# Model tag as shown by `ollama list`.
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_BASE_URL=http://localhost:11434
# Optional: how long, in seconds, to wait for a single generation.
OLLAMA_TIMEOUT=600
# Context window. Ollama DEFAULTS to 2048 regardless of the model's real window,
# which truncates the RAG prompt and makes the model return nothing — so we set it.
# KV cache ≈ 56 KB/token for a 9B model: 16k≈0.9 GB, 32k≈1.8 GB, 128k≈7 GB,
# 256k≈15 GB. The ceiling is your RAM/VRAM, not the model — on 14 GB RAM / 8 GB
# VRAM, 16k is the sweet spot and 128k+ will OOM. A bigger window does NOT improve
# output; it only needs to fit the prompt (~5-8k tokens here).
# NOTE: the UI now exposes a per-run "Context window" slider that is auto-sized to your GPU
# VRAM (GET /api/system/caps). OLLAMA_NUM_CTX is the fallback default when the slider is unset.
OLLAMA_NUM_CTX=32768
# How the VRAM-aware slider max is computed (KV-cache budget = VRAM - weights, / bytes-per-token):
OLLAMA_KV_BYTES_PER_TOKEN=57344   # ~56 KB/token for this 9B model
OLLAMA_RESERVE_GB=6.0             # VRAM the model weights+overhead occupy before the KV cache
OLLAMA_CTX_HARD_MAX=262144        # absolute ceiling regardless of VRAM (qwen3.5 window)
# Thinking pass (qwen3). 0 = off (fast, content streams immediately) · 1 = show reasoning.
OLLAMA_THINK=0

# ---------------------------------------------------------------------
# RAG retrieval quality (so the small-context model gets the BEST chunks)
#   Recall is hybrid: dense (pgvector) + lexical (Postgres full-text), merged by
#   Reciprocal Rank Fusion, then a local cross-encoder RERANKS and keeps only the
#   few most-relevant chunks. Both stages degrade gracefully if disabled/unavailable.
# ---------------------------------------------------------------------
GARUDA_RAG_HYBRID=1               # 0 = dense-only (skip lexical + fusion)
GARUDA_RAG_RERANK=1               # 0 = skip cross-encoder reranking (use fusion order)
# Local reranker model (downloaded once). bge-reranker-base is stronger but ~1.1 GB.
GARUDA_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# Reranker runs on CPU by default (leaves VRAM for Ollama). Set to cuda to use the GPU.
GARUDA_RERANKER_DEVICE=cpu

# --- Google Gemini (cloud, optional fallback) -----------------------
# Only used when LLM_PROVIDER=google.
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-pro

# ---------------------------------------------------------------------
# EMBEDDINGS PROVIDER (for the FAISS RAG indexes)
#   huggingface -> local sentence-transformers (DEFAULT, matches the
#                  prebuilt indexes which use all-MiniLM-L6-v2 / 384-dim)
#   ollama      -> Ollama embeddings (only if you rebuild the indexes)
#   google      -> Google embeddings (only if you rebuild the indexes)
# Keep this on "huggingface" unless you regenerate data/verilog_datasets.
# ---------------------------------------------------------------------
EMBEDDINGS_PROVIDER=huggingface
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Used only when EMBEDDINGS_PROVIDER=ollama
OLLAMA_EMBED_MODEL=nomic-embed-text

# ---------------------------------------------------------------------
# LibreLane (RTL -> GDSII backend, installed via Nix)
# ---------------------------------------------------------------------
# Path to the librelane CLI provided by the Nix profile. Leave as "librelane"
# if it is already on PATH (it is after `nix profile add github:librelane/librelane`).
LIBRELANE_BIN=librelane
# Default open-source PDK used for hardening.
PDK=gf180mcuD
# Where Ciel installs PDKs (LibreLane reads PDK_ROOT). Set up by scripts/install.sh.
PDK_ROOT=/home/irman/.ciel

# --------------------------------------------------------------------------- #
# Durable knowledge store (the RLM's long-term memory) — Postgres(pgvector) +
# MinIO object storage, GarudaChip's OWN docker stack (docker-compose.yml).
# Bring it up with: docker compose up -d   (ports 5433 / 9100-9101).
# A committed seed (data/knowledge_seed/) auto-loads on first run so the store is
# never empty. Set GARUDA_MEMORY=0 to disable and run pure-local.
# --------------------------------------------------------------------------- #
GARUDA_MEMORY=1
GARUDA_DATABASE_URL=postgresql+psycopg://garuda:garuda@localhost:5433/garudachip
GARUDA_S3_ENDPOINT_URL=http://localhost:9100
GARUDA_S3_ACCESS_KEY=garuda
GARUDA_S3_SECRET_KEY=garudasecret
GARUDA_S3_BUCKET=garudachip
GARUDA_S3_REGION=us-east-1
